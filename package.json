{
  "name": "transport-connect",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && node -e \"require('fs').writeFileSync(require('path').join('dist','.nojekyll'),'')\"",
    "serve:web": "npx --yes serve dist -l 8080"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@mapbox/mapbox-sdk": "^0.16.2",
    "@react-native-mapbox-gl/maps": "^8.5.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@types/react-dom": "~19.1.7",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-haptics": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-vector-icons": "^10.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "babel-preset-expo": "~54.0.10"
  }
}
